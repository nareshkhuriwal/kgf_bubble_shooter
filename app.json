{
  "expo": {
    "name": "Bubble Kingdom",
    "slug": "bubble-kingdom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/bubble-kingdom-icon-master.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/kgf-orbito-splash-master.png",
      "resizeMode": "cover",
      "backgroundColor": "#0d0514"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.khuriwalgroup",
      "infoPlist": {
        "UIStatusBarStyle": "UIStatusBarStyleLightContent"
      }
    },
    "android": {
      "package": "com.khuriwalgroup",
      "statusBar": {
        "barStyle": "light-content",
        "backgroundColor": "#0f0f2e"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/bubble-kingdom-icon-master.png",
        "backgroundColor": "#0d0514"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-av"
    ],
    "extra": {
      "eas": {
        "projectId": "6765a13c-621d-444e-9428-8d1e3c339141"
      }
    },
    "owner": "nareshkhuriwal"
  }
}
